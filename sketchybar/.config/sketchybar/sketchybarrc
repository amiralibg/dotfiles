#!/usr/bin/env bash

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ sketchybar — top status bar for the yabai setup                          │
# │ Left: apple · space pills (tagged by keybind) · front app                │
# │ Right: wifi · volume · battery · clock                                    │
# ╰──────────────────────────────────────────────────────────────────────────╯

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

FONT="SF Pro"
NERD="Symbols Nerd Font"   # installed via `brew install font-symbols-only-nerd-font`

# ── Bar ──────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=37 \
  position=top \
  sticky=on \
  blur_radius=30 \
  color=$BAR_COLOR \
  padding_left=8 \
  padding_right=8 \
  corner_radius=0 \
  y_offset=0 \
  margin=0

# ── Defaults ─────────────────────────────────────────────────────────────────
sketchybar --default \
  updates=when_shown \
  icon.font="$NERD:Bold:15.0" \
  icon.color=$TEXT \
  icon.padding_left=8 \
  icon.padding_right=4 \
  label.font="$FONT:Semibold:13.0" \
  label.color=$TEXT \
  label.padding_left=4 \
  label.padding_right=8 \
  background.color=$ITEM_BG \
  background.corner_radius=8 \
  background.height=24 \
  background.drawing=off \
  padding_left=3 \
  padding_right=3

# ── Apple ────────────────────────────────────────────────────────────────────
sketchybar --add item apple left \
  --set apple icon="" icon.font="$NERD:Black:16.0" icon.color=$MAUVE \
        label.drawing=off background.drawing=off \
        icon.padding_left=6 icon.padding_right=6 \
        click_script="open -a 'System Settings'"

# ── Spaces (one pill per Desktop, tagged by its keybind) ─────────────────────
# space_tag maps a space label → the key you press for it (alt-<tag>).
# NOTE: sketchybar runs this with system bash 3.2 (no associative arrays),
# so we use a case statement, not `declare -A`.
space_tag() {
  case "$1" in
    main) echo "1" ;; term) echo "I" ;; code) echo "C" ;; web) echo "B" ;;
    chat) echo "D" ;; ai) echo "G" ;; design) echo "O" ;;
    two) echo "2" ;; three) echo "3" ;; five) echo "5" ;; six) echo "6" ;;
    seven) echo "7" ;; eight) echo "8" ;; nine) echo "9" ;;
    *) echo "$2" ;;
  esac
}
for sid in $(yabai -m query --spaces | jq -r '.[].index'); do
  lbl=$(yabai -m query --spaces --space "$sid" | jq -r '.label')
  tag=$(space_tag "$lbl" "$sid")
  sketchybar --add space space.$sid left \
    --set space.$sid \
          icon="$tag" \
          icon.font="$FONT:Bold:13.0" \
          label.drawing=off \
          background.drawing=on \
          background.color=$ITEM_BG \
          background.corner_radius=8 \
          background.height=24 \
          click_script="yabai -m space --focus $sid" \
          script="$PLUGIN_DIR/space.sh" \
    --subscribe space.$sid space_change mouse.clicked
done

# separator
sketchybar --add item space.sep left \
  --set space.sep icon="" icon.color=$SURFACE label.drawing=off \
        background.drawing=off icon.padding_left=6 icon.padding_right=6

# ── Front app ────────────────────────────────────────────────────────────────
sketchybar --add item front_app left \
  --set front_app icon.drawing=off \
        label.font="$FONT:Bold:13.0" label.color=$PEACH \
        background.drawing=off \
        script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# ── Right side (added right-to-left) ─────────────────────────────────────────
sketchybar --add item clock right \
  --set clock update_freq=10 icon="" icon.color=$BLUE \
        background.drawing=on \
        script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --set battery update_freq=120 \
        background.drawing=on \
        script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --add item volume right \
  --set volume background.drawing=on \
        script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

sketchybar --add item wifi right \
  --set wifi update_freq=30 \
        background.drawing=on \
        script="$PLUGIN_DIR/wifi.sh" \
  --subscribe wifi wifi_change

# ── Finalize ─────────────────────────────────────────────────────────────────
sketchybar --update
echo "sketchybar config loaded."
